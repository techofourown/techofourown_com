---
import { getCollection, render } from "astro:content";
import RelatedLinkCard from "../../components/RelatedLinkCard.astro";
import VideoPlayer from "../../components/VideoPlayer.astro";
import ContentLayout from "../../layouts/ContentLayout.astro";

const dateFormatter = new Intl.DateTimeFormat("en-US", { dateStyle: "long", timeZone: "UTC" });
const formatLabel = (format: "text" | "image" | "video" | "audio" | "mixed") =>
  format === "mixed" ? "Mixed media" : `${format.charAt(0).toUpperCase()}${format.slice(1)}`;

export async function getStaticPaths() {
  const entries = await getCollection("drumbeat", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const publishedDate = dateFormatter.format(entry.data.publishedAt);
const metaItems = [
  { label: "Published", value: publishedDate },
  { label: "Format", value: formatLabel(entry.data.format) },
  ...(entry.data.runtime ? [{ label: "Runtime", value: entry.data.runtime }] : []),
];
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  eyebrow="Drumbeat"
  metaItems={metaItems}
  ogImage={entry.data.coverImage.src}
  ogImageAlt={entry.data.coverImageAlt}
  ogType="article"
  publishedTime={entry.data.publishedAt.toISOString()}
>
  <div class="drumbeat-detail">
    {
      entry.data.videoUrl ? (
        <VideoPlayer
          title={entry.data.title}
          videoUrl={entry.data.videoUrl}
          poster={entry.data.coverImage.src}
        />
      ) : entry.data.audioUrl ? (
        <section class="drumbeat-media drumbeat-media--audio">
          <audio controls preload="metadata" src={entry.data.audioUrl}>
            Your browser does not support HTML5 audio.
          </audio>
          <p class="video-player__link-row">
            Direct audio:
            <a href={entry.data.audioUrl}>{entry.data.title}</a>
          </p>
        </section>
      ) : (
        <figure class="drumbeat-media">
          <img
            src={entry.data.coverImage.src}
            width={entry.data.coverImage.width}
            height={entry.data.coverImage.height}
            alt={entry.data.coverImageAlt}
          />
        </figure>
      )
    }

    <div class="drumbeat-detail__body">
      <Content />
    </div>

    {
      entry.data.links.length > 0 && (
        <section class="drumbeat-detail__section">
          <h2 class="drumbeat-detail__title">Related links</h2>
          <div class="card-grid card-grid--two">
            {entry.data.links.map((link) => (
              <RelatedLinkCard {...link} />
            ))}
          </div>
        </section>
      )
    }

    {
      entry.data.mirrors.length > 0 && (
        <section class="drumbeat-detail__section">
          <h2 class="drumbeat-detail__title">Mirrors</h2>
          <p>Platforms are mirrors. This site is the canonical home.</p>
          <div class="mirror-link-row">
            {entry.data.mirrors.map((mirror) => (
              <a class="mirror-link" href={mirror.href} target="_blank" rel="noreferrer">
                {mirror.label}
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</ContentLayout>
