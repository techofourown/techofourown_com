---
import { getCollection } from "astro:content";
import CollectionCard from "../../../components/CollectionCard.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import SiteNav from "../../../components/SiteNav.astro";
import { site } from "../../../data/site";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const hasEntries = Object.keys(import.meta.glob("/src/content/decisions/**/*.{md,mdx}")).length > 0;
const entries = hasEntries
  ? (await getCollection("decisions", ({ data }) => !data.draft)).sort((a, b) => {
      const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
      const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
      if (orderA !== orderB) return orderA - orderB;
      return (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0);
    })
  : [];
---

<BaseLayout title="Library Decisions | Tech of Our Own" description="Public architectural decisions and the tradeoffs behind them.">
  <main class="site-page">
    <SiteNav />
    <div class="site-main">
      <section class="section-block">
        <p class="site-hero__eyebrow">Library / Decisions</p>
        <h1 class="section-block__title">Public decisions.</h1>
        <p class="section-block__lede">
          These entries explain the decisions we want people to be able to read without living inside
          the repo.
        </p>
      </section>

      {
        entries.length > 0 ? (
          <section class="collection-grid">
            {entries.map((entry) => (
              <CollectionCard
                href={`/library/decisions/${entry.id}/`}
                title={entry.data.title}
                description={entry.data.summary ?? entry.data.description}
                meta={[entry.data.status]}
              />
            ))}
          </section>
        ) : (
          <div class="empty-state">No public decisions yet.</div>
        )
      }
    </div>
    <SiteFooter
      description="Public decisions are adapted for readers; maintainer-only operational docs stay in the repo."
      links={[
        { href: "/library/", label: "Back to Library" },
        { href: site.githubOrgUrl, label: "View the GitHub org", external: true },
      ]}
    />
  </main>
</BaseLayout>
