---
import PathCard from "../../components/PathCard.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteNav from "../../components/SiteNav.astro";
import { ourBoxPaths } from "../../data/ourbox-paths";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="OurBox | Tech of Our Own"
  description="Choose the current OurBox self-build path: Matchbox for Raspberry Pi or Woodbox for x86."
>
  <main class="site-page">
    <SiteNav />

    <div class="site-main">
      <section class="site-hero">
        <span class="site-hero__eyebrow">OurBox</span>
        <h1 class="site-hero__title">Choose an OurBox path.</h1>
        <p class="site-hero__lede">
          OurBox is the umbrella for practical, self-build personal server paths. Right now there
          are two public starting points: Matchbox for Raspberry Pi and Woodbox for x86.
        </p>
        <div class="site-actions">
          <a class="button" href="/matchbox/">Matchbox</a>
          <a class="button button--secondary" href="/woodbox/">Woodbox</a>
          <a class="button button--secondary" href={site.githubOrgUrl}>Public GitHub</a>
        </div>
        <p class="note-row">Choose a box first. Build guides, videos, and discussion plug in later.</p>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">Two public paths today</h2>
        <p class="section-block__lede">
          Both paths stay local-first, open, and build-it-yourself. The practical choice is mostly
          about platform and headroom.
        </p>
        <div class="card-grid card-grid--two">
          {ourBoxPaths.map((path) => <PathCard {...path} ctaLabel={`Open ${path.title}`} />)}
        </div>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">What stays the same across both</h2>
        <article class="card">
          <div class="card__body">
            <ul class="bullet-list">
              <li>Local-first by default.</li>
              <li>Open source software and public documentation.</li>
              <li>Open hardware designs people can inspect and build themselves.</li>
              <li>No subscription dependency for the core product path.</li>
              <li>A practical, self-hosted appliance model instead of a cloud lock-in model.</li>
            </ul>
          </div>
        </article>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">Coming later</h2>
        <article class="card">
          <h3 class="card__title">More paths, after these two are real</h3>
          <div class="card__body">
            <p>
              Tinderbox and other variants may come later. For this phase, Matchbox and Woodbox are
              the real public paths and the only ones we want new visitors to evaluate first.
            </p>
            <p>
              We are keeping the structure clean now so future media, docs, and forum threads have a
              clear place to land.
            </p>
          </div>
        </article>
      </section>
    </div>

    <SiteFooter
      description="OurBox is the umbrella. Matchbox and Woodbox are the two real public paths for this phase."
      links={[
        { href: "/matchbox/", label: "Open Matchbox" },
        { href: "/woodbox/", label: "Open Woodbox" },
        { href: site.githubOrgUrl, label: "Browse the GitHub org", external: true },
      ]}
    />
  </main>
</BaseLayout>
