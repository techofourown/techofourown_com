---
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | Tech of Our Own">
  <main class="site-page">
    <SiteNav />

    <section class="not-found-page">
      <div class="not-found-card">
        <h1 class="not-found-card__title">We couldn’t find that page.</h1>
        <p class="not-found-card__lede">
          The link may be outdated or the page might have moved. Use the shortcuts below to get back
          on track.
        </p>
        <div class="not-found-card__actions">
          <a class="button" href="/">Home</a>
          <a class="button button--secondary" href="/ourbox">OurBox</a>
          <a class="button button--secondary" href={site.githubOrgUrl}>Public GitHub</a>
        </div>
        <p class="not-found-card__note">No trackers. No ads. Just static HTML.</p>
      </div>
    </section>

    <SiteFooter
      description="Tech of Our Own keeps the public site static, direct, and first-party."
      links={[
        { href: "/ourbox", label: "Explore OurBox ->" },
        { href: site.githubOrgUrl, label: "See the public GitHub ->", external: true },
      ]}
    />
  </main>
</BaseLayout>
