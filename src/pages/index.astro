    <SiteFooter
      description="Tech of Our Own is building the next generation of consumer technology with privacy, autonomy, and longevity at the core."
      links={[
        { href: "/ourbox/", label: "Explore the OurBox product page ->" },
        { href: site.githubOrgUrl, label: "See the public Tech of Our Own GitHub ->", external: true },
      ]}
    />
  </main>
</BaseLayout>
