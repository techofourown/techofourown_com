---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const hasEntries = Object.keys(import.meta.glob("/src/content/journal/**/*.{md,mdx}")).length > 0;
  if (!hasEntries) return [];

  const entries = await getCollection("journal", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const metaItems = [{ label: "Published", value: entry.data.publishedAt.toISOString().slice(0, 10) }];
---

<ContentLayout title={entry.data.title} description={entry.data.description} eyebrow="Journal" metaItems={metaItems}>
  <Content />
</ContentLayout>
