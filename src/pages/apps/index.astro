---
import { getCollection } from "astro:content";
import CollectionCard from "../../components/CollectionCard.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteNav from "../../components/SiteNav.astro";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const hasEntries = Object.keys(import.meta.glob("/src/content/apps/**/*.{md,mdx}")).length > 0;
const entries = hasEntries
  ? (await getCollection("apps", ({ data }) => !data.draft)).sort((a, b) => {
      const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
      const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
      if (orderA !== orderB) return orderA - orderB;
      return (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0);
    })
  : [];
---

<BaseLayout title="Apps | Tech of Our Own" description="Application entries connected to the broader Tech of Our Own ecosystem.">
  <main class="site-page">
    <SiteNav />
    <div class="site-main">
      <section class="section-block">
        <p class="site-hero__eyebrow">Apps</p>
        <h1 class="section-block__title">Application entries will land here when they are real.</h1>
        <p class="section-block__lede">
          The route exists now so the publishing system is ready, but the nav stays conservative until
          real app entries are published.
        </p>
      </section>

      {
        entries.length > 0 ? (
          <section class="collection-grid">
            {entries.map((entry) => (
              <CollectionCard
                href={`/apps/${entry.id}`}
                title={entry.data.title}
                description={entry.data.summary ?? entry.data.description}
                meta={[entry.data.status]}
              />
            ))}
          </section>
        ) : (
          <div class="empty-state">No public app entries yet.</div>
        )
      }
    </div>
    <SiteFooter
      description="Apps stay out of the nav until there is real content to point people to."
      links={[
        { href: "/ourbox", label: "Explore OurBox" },
        { href: site.githubOrgUrl, label: "View the GitHub org", external: true },
      ]}
    />
  </main>
</BaseLayout>
