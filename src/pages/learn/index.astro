---
import { getCollection } from "astro:content";
import CollectionCard from "../../components/CollectionCard.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteNav from "../../components/SiteNav.astro";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const hasEntries = Object.keys(import.meta.glob("/src/content/learn/**/*.{md,mdx}")).length > 0;
const entries = hasEntries
  ? (await getCollection("learn", ({ data }) => !data.draft)).sort((a, b) => {
      const orderA = a.data.order ?? Number.MAX_SAFE_INTEGER;
      const orderB = b.data.order ?? Number.MAX_SAFE_INTEGER;
      if (orderA !== orderB) return orderA - orderB;
      return (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0);
    })
  : [];
---

<BaseLayout title="Learn | Tech of Our Own" description="Walkthroughs and learning material for building technology people can own.">
  <main class="site-page">
    <SiteNav />
    <div class="site-main">
      <section class="section-block">
        <p class="site-hero__eyebrow">Learn</p>
        <h1 class="section-block__title">Guided walkthroughs and practical lessons.</h1>
        <p class="section-block__lede">
          This section gathers structured walkthroughs, setup lessons, and product-oriented learning
          material.
        </p>
      </section>

      {
        entries.length > 0 ? (
          <section class="collection-grid">
            {entries.map((entry) => (
              <CollectionCard
                href={`/learn/${entry.id}/`}
                title={entry.data.title}
                description={entry.data.summary ?? entry.data.description}
                meta={[entry.data.runtime ?? "", entry.data.noindex ? "Noindex" : ""].filter(Boolean)}
              />
            ))}
          </section>
        ) : (
          <div class="empty-state">No public learn entries yet.</div>
        )
      }
    </div>
    <SiteFooter
      description="Learn pages stay static-first and first-party. Videos stream directly from our media origin."
      links={[
        { href: "/ourbox/", label: "Explore OurBox" },
        { href: site.githubOrgUrl, label: "View the GitHub org", external: true },
      ]}
    />
  </main>
</BaseLayout>
