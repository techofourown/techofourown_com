---
import SiteFooter from "../../components/SiteFooter.astro";
import SiteNav from "../../components/SiteNav.astro";
import { ourBoxPaths } from "../../data/ourbox-paths";
import BaseLayout from "../../layouts/BaseLayout.astro";

const woodbox = ourBoxPaths.find((path) => path.key === "woodbox");

if (!woodbox) {
  throw new Error("Woodbox path metadata is missing.");
}

const woodboxDocsUrl = woodbox.docsUrl;

if (!woodboxDocsUrl) {
  throw new Error("Woodbox docs URL is missing.");
}
---

<BaseLayout title="Woodbox | Tech of Our Own" description={woodbox.summary}>
  <main class="site-page">
    <SiteNav />

    <div class="site-main">
      <section class="site-hero">
        <span class="site-hero__eyebrow">OurBox / Woodbox</span>
        <h1 class="site-hero__title">Woodbox</h1>
        <p class="site-hero__lede">
          Woodbox is the x86 path: more headroom, more storage options, and a broader service
          footprint for people who want a stronger self-build server base.
        </p>
        <div class="site-actions">
          <a class="button" href={woodboxDocsUrl}>GitHub docs</a>
          <a class="button button--secondary" href="/ourbox/">Back to OurBox</a>
        </div>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">At a glance</h2>
        <div class="card-grid card-grid--two">
          <article class="card">
            <h3 class="card__title">Platform</h3>
            <div class="card__body"><p>x86</p></div>
          </article>
          <article class="card">
            <h3 class="card__title">Best for</h3>
            <div class="card__body"><p>More headroom, more storage, broader service footprint.</p></div>
          </article>
          <article class="card">
            <h3 class="card__title">Status</h3>
            <div class="card__body"><p>Foundational page, expanding over time.</p></div>
          </article>
          <article class="card">
            <h3 class="card__title">Current phase</h3>
            <div class="card__body"><p>Build-it-yourself.</p></div>
          </article>
        </div>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">What Woodbox is</h2>
        <div class="prose">
          <!-- TODO: replace with final Woodbox positioning copy -->
          <p>
            Woodbox is the larger public OurBox path. It is the route for people who want more
            storage flexibility, more service headroom, and the practical advantages of an x86
            build.
          </p>
          <p>
            This page is the canonical landing surface for the x86 path. Older procurement material
            can remain in the repo, but this page is where the future user-facing structure belongs.
          </p>
        </div>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">Who should choose Woodbox</h2>
        <article class="card">
          <div class="card__body">
            <ul class="bullet-list">
              <li>People who want more headroom than the Raspberry Pi path offers.</li>
              <li>People who expect broader storage or service needs over time.</li>
              <li>People who want an x86 starting point for a self-hosted home server.</li>
              <li>People who want a stronger base before media, docs, and discussion fill in.</li>
            </ul>
          </div>
        </article>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">What this page will eventually contain</h2>
        <div class="card-grid card-grid--two">
          <article class="card">
            <h3 class="card__title">Build and setup materials</h3>
            <div class="card__body">
              <ul class="bullet-list">
                <li>Hardware bill of materials</li>
                <li>Assembly steps</li>
                <li>Install and provision steps</li>
                <li>Software and app setup</li>
              </ul>
            </div>
          </article>
          <article class="card">
            <h3 class="card__title">Support materials</h3>
            <div class="card__body">
              <ul class="bullet-list">
                <li>Troubleshooting</li>
                <li>Photos</li>
                <li>Video walkthrough</li>
                <li>Path-specific discussion thread</li>
              </ul>
            </div>
          </article>
        </div>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">Video walkthrough</h2>
        <article class="card">
          <h3 class="card__title">Coming soon</h3>
          <div class="card__body">
            <!-- TODO: add canonical video when ready -->
            <p>
              Video walkthrough coming soon. This page is the canonical landing surface for that
              future video.
            </p>
          </div>
        </article>
      </section>

      <section class="section-block">
        <h2 class="section-block__title">Canonical docs</h2>
        <article class="card">
          <h3 class="card__title">Living technical record</h3>
          <div class="card__body">
            <p>
              The GitHub docs are the living technical record while this public page is still being
              filled in.
            </p>
          </div>
          <div class="site-actions">
            <a class="button" href={woodboxDocsUrl}>Open Woodbox docs on GitHub</a>
          </div>
        </article>
      </section>

      <!--
      <section class="section-block">
        <h2 class="section-block__title">Future discussion</h2>
        <article class="card">
          <div class="card__body">
            <p>Path-specific discussion will live here when the forum is ready.</p>
          </div>
        </article>
      </section>
      -->
    </div>

    <SiteFooter
      description="Woodbox is the canonical x86 path page for this phase."
      links={[
        { href: "/ourbox/", label: "Back to OurBox" },
        { href: "/matchbox/", label: "Compare Matchbox" },
        { href: woodboxDocsUrl, label: "Open GitHub docs", external: true },
      ]}
    />
  </main>
</BaseLayout>
