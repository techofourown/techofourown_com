---
import { site } from "../data/site";
import "../styles/theme.css";

interface Props {
  title: string;
  description?: string;
  robots?: string;
  referrer?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  publishedTime?: string;
}

const {
  title,
  description = site.defaultDescription,
  robots,
  referrer,
  ogImage,
  ogImageAlt,
  ogType = "website",
  publishedTime,
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const resolvedOgImage = ogImage && Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const twitterCard = resolvedOgImage ? "summary_large_image" : "summary";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {robots && <meta name="robots" content={robots} />}
    {referrer && <meta name="referrer" content={referrer} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    {resolvedOgImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    {resolvedOgImage && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
  </head>
  <body>
    <slot />
  </body>
</html>
