---
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import { site } from "../data/site";
import BaseLayout from "./BaseLayout.astro";

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  metaItems?: MetaItem[];
  robots?: string;
  referrer?: string;
}

const {
  title,
  description,
  eyebrow,
  metaItems = [],
  robots,
  referrer,
} = Astro.props;
---

<BaseLayout title={`${title} | ${site.name}`} description={description} robots={robots} referrer={referrer}>
  <main class="site-page">
    <SiteNav />

    <div class="site-main">
      <article class="content-layout">
        <header class="content-layout__header">
          {eyebrow && <p class="site-hero__eyebrow">{eyebrow}</p>}
          <h1 class="content-layout__title">{title}</h1>
          <p class="content-layout__description">{description}</p>
          {
            metaItems.length > 0 && (
              <dl class="content-layout__meta">
                {metaItems.map((item) => (
                  <div class="content-layout__meta-item">
                    <dt>{item.label}</dt>
                    <dd>{item.value}</dd>
                  </div>
                ))}
              </dl>
            )
          }
        </header>

        <div class="prose">
          <slot />
        </div>
      </article>
    </div>

    <SiteFooter
      description="Tech of Our Own keeps the public site open, first-party, and easy to inspect."
      links={[
        { href: "/ourbox/", label: "Explore OurBox" },
        { href: site.githubOrgUrl, label: "View the GitHub org", external: true },
      ]}
    />
  </main>
</BaseLayout>
