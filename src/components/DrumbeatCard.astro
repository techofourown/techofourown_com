---
type CoverImage = {
  src: string;
  width: number;
  height: number;
};

interface Props {
  href: string;
  title: string;
  description: string;
  publishedAt: string;
  format: string;
  coverImage: CoverImage;
  coverImageAlt: string;
  featured?: boolean;
}

const {
  href,
  title,
  description,
  publishedAt,
  format,
  coverImage,
  coverImageAlt,
  featured = false,
} = Astro.props;
---

<article
  class:list={{
    card: true,
    "drumbeat-card": true,
    "drumbeat-card--featured": featured,
  }}
>
  <a class="drumbeat-card__link" href={href}>
    <div class="drumbeat-card__media">
      <span class="drumbeat-card__format">{format}</span>
      <img
        src={coverImage.src}
        width={coverImage.width}
        height={coverImage.height}
        alt={coverImageAlt}
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="drumbeat-card__content">
      <p class="drumbeat-card__meta">{publishedAt}</p>
      <h2 class="drumbeat-card__title">{title}</h2>
      <p class="drumbeat-card__summary">{description}</p>
      <span class="drumbeat-card__cta">Read entry →</span>
    </div>
  </a>
</article>
