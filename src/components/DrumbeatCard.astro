---
type MediaImage = {
  src: string;
  width: number;
  height: number;
};

interface Props {
  href: string;
  title: string;
  description: string;
  publishedAt: string;
  format: string;
  cardImage: MediaImage;
  cardImageAlt: string;
  cardImageFit?: "cover" | "contain";
  cardImagePosition?: string;
  featured?: boolean;
}

const {
  href,
  title,
  description,
  publishedAt,
  format,
  cardImage,
  cardImageAlt,
  cardImageFit = "cover",
  cardImagePosition,
  featured = false,
} = Astro.props;
---

<article
  class:list={{
    card: true,
    "drumbeat-card": true,
    "drumbeat-card--featured": featured,
    "drumbeat-card--cover": cardImageFit === "cover",
    "drumbeat-card--contain": cardImageFit === "contain",
  }}
>
  <a class="drumbeat-card__link" href={href}>
    <div class="drumbeat-card__media" style={`--media-position: ${cardImagePosition ?? "center"};`}>
      <span class="drumbeat-card__format">{format}</span>
      <div class="drumbeat-card__media-frame">
        <img
          src={cardImage.src}
          width={cardImage.width}
          height={cardImage.height}
          alt={cardImageAlt}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div class="drumbeat-card__content">
      <p class="drumbeat-card__meta">{publishedAt}</p>
      <h2 class="drumbeat-card__title">{title}</h2>
      <p class="drumbeat-card__summary">{description}</p>
      <span class="drumbeat-card__cta">Read entry →</span>
    </div>
  </a>
</article>
